# SO-101 + SmolVLA 環境変数テンプレート
# cp .env.example .env して各値を設定してください

# HuggingFace
HUGGINGFACE_TOKEN=hf_xxx
HF_USER=your_hf_username

# データセット設定
DATASET_NAME=so101_pick_place_cube
TASK_DESCRIPTION="Grasp the red cube and place it in the white bin."

# ハードウェアポート (lerobot-find-port で確認)
FOLLOWER_PORT=/dev/tty.usbmodem585A0076841
LEADER_PORT=/dev/tty.usbmodem575E0031751
FOLLOWER_ID=my_so101_follower
LEADER_ID=my_so101_leader

# ポリシー (学習後に設定)
POLICY_NAME=smolvla_so101_pick_place
POLICY_PATH=outputs/train/smolvla_so101_pick_place/checkpoints/last/pretrained_model

# W&B (学習監視)
WANDB_API_KEY=
WANDB_PROJECT=so101-vla

# GCP
GCP_PROJECT=your-gcp-project
GCP_REGION=us-central1
